generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Mission {
  id          Int                @id @default(autoincrement())
  image       String
  mission     String
  type        String
  targets     Target[]
  leaderboard LeaderboardEntry[]
}

model Target {
  id        Int     @id @default(autoincrement())
  name      String
  locations String
  mission   Mission @relation(fields: [missionId], references: [id])
  missionId Int
}

model LeaderboardEntry {
  id        Int      @id @default(autoincrement())
  name      String
  time      Int
  date      DateTime @default(now())
  mission   Mission  @relation(fields: [missionId], references: [id])
  missionId Int
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
  startDate DateTime @default(now())
}
